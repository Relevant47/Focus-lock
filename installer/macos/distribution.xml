<?xml version="1.0" encoding="utf-8"?>
<!--
  FocusLock macOS PKG distribution
  Build:
    pkgbuild --root pkg-root --scripts scripts \
             --identifier com.focuslock.daemon \
             --version 1.0.0 \
             FocusLockDaemon.pkg
    productbuild --distribution distribution.xml \
                 --resources resources \
                 --package-path . \
                 FocusLock-1.0.0.pkg
-->
<installer-gui-script minSpecVersion="2">
  <title>FocusLock</title>
  <welcome    file="welcome.html"    mime-type="text/html" />
  <license    file="LICENSE.txt"     mime-type="text/plain" />
  <conclusion file="conclusion.html" mime-type="text/html" />

  <options customize="never" require-scripts="true" rootVolumeOnly="true" />

  <volume-check>
    <allowed-os-versions>
      <os-version min="13" />
    </allowed-os-versions>
  </volume-check>

  <choices-outline>
    <line choice="com.focuslock.daemon" />
    <line choice="com.focuslock.ui" />
  </choices-outline>

  <choice id="com.focuslock.daemon" title="FocusLock Daemon" description="Background service that enforces website and app blocking." enabled="false" selected="true">
    <pkg-ref id="com.focuslock.daemon" />
  </choice>

  <choice id="com.focuslock.ui" title="FocusLock App" description="Dashboard and control interface." enabled="false" selected="true">
    <pkg-ref id="com.focuslock.ui" />
  </choice>

  <pkg-ref id="com.focuslock.daemon" version="1.0.0" onConclusion="none">FocusLockDaemon.pkg</pkg-ref>
  <pkg-ref id="com.focuslock.ui"     version="1.0.0" onConclusion="none">FocusLockUI.pkg</pkg-ref>
</installer-gui-script>
